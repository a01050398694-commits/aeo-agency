# ===============================================
# AEO Agency 환경변수 템플릿
# 사용법: cp .env.example .env → 실제 값 입력
# ⚠️ .env 파일은 절대 커밋 금지 (.gitignore 적용됨)
# ===============================================

# --- AI / 검색 ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Google APIs ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# OAuth 콜백 (대시보드)
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Notion ---
NOTION_TOKEN=
NOTION_OPS_DB_ID=
NOTION_QUEUE_DB_ID=

# --- Slack 알림 ---
SLACK_WEBHOOK_URL=
SLACK_CHANNEL_OPS=#ops-alerts
SLACK_CHANNEL_REPORTS=#client-reports

# --- 이메일 (보고서 발송) ---
RESEND_API_KEY=
FROM_EMAIL=reports@youragency.com

# --- Vercel (배포) ---
VERCEL_TOKEN=
VERCEL_PROJECT_ID=

# --- 기타 ---
NODE_ENV=development
TZ=Asia/Seoul
